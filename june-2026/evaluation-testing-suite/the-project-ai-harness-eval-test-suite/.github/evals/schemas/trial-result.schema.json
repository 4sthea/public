{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "the project AI Eval Trial Result",
  "type": "object",
  "required": [
    "task_id",
    "variant",
    "trial",
    "output_path",
    "pass",
    "score",
    "checks"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "variant": {
      "type": "string"
    },
    "trial": {
      "type": "integer"
    },
    "output_path": {
      "type": "string"
    },
    "pass": {
      "type": "boolean"
    },
    "score": {
      "type": "number"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
